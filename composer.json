{
  "name": "egglose5/aims",
  "description": "AIMS WordPress plugin test harness",
  "type": "wordpress-plugin",
  "license": "Apache-2.0",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^10.5"
  },
  "autoload-dev": {
    "psr-4": {
      "AIMS\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
